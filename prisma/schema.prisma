generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VENDEUR
  ACHETEUR
  ADMIN
}

enum OpportuniteStatus {
  PENDING
  ACTIVE
  HIDDEN
  CLOSED
}

enum TypeDeal {
  VENTE
  FUSION
  OUVERTURE_CAPITAL
  COLLABORATION
  LIQUIDATION
}

enum PresenceDirigeant {
  OUI
  OUI_PROVISOIRE
  NON
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  messages  Message[]
  vendeur  Vendeur?
  acheteur Acheteur?
  resetTokens  PasswordResetToken[]
}

model Vendeur {
  id           String @id @default(cuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nomBureau    String
  nomCEO       String
  logoUrl      String?
  adresse      String?
  telephone    String?
  emailContact String?
  numeroBce    String?
  opportunites Opportunite[]

}

model Acheteur {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  stripeCustomerId String?
  stripeSubId      String?
  subStatus        String?
  alertesEmail     Boolean @default(true)

  // Filtres alertes
  alerteProvinces  String[]
  alerteTypeDeals  String[]
  alerteCaMin      Float?
  alerteCaMax      Float?

  // Profil étendu
  nomBureau        String?
  nomCEO           String?
  telephone        String?
  adresse          String?
  siteInternet     String?
  chiffreAffaires  Float?
  nombreClients    Int?
  nombreCollaborateurs Int?
  activites        String[]

  deblocages       Deblocage[]
}

model Opportunite {
  id                   String            @id @default(cuid())
  vendeurId            String
  vendeur              Vendeur           @relation(fields: [vendeurId], references: [id], onDelete: Cascade)

  province             String
  chiffreAffaires      Float
  nombreClients        Int
  nombreCollaborateurs Int
  activites            String[]
  typeDeal             TypeDeal[]
  presenceDirigeant    PresenceDirigeant
  description          String?
  logiciels            String?

  montantRevente       String?
  typeVente            String?

  utiliseBrio              Boolean?
  exclusiviteCompagnie     Boolean?
  nomCompagnie             String?
  venteImmeuble            Boolean?
  dossierDigitalise        Boolean?

  caIard               Float?
  caVie                Float?
  caCreditImmo         Float?
  caCreditTempo        Float?
  caPlacement          Float?
  caBanque             Float?

  adressesComplementaires String[]

  // Compteurs de vues
  vuesPubliques        Int @default(0)
  vuesAbonnes          Int @default(0)

  status               OpportuniteStatus @default(ACTIVE)
  createdAt            DateTime          @default(now())

  deblocages           Deblocage[]
  valeurImmeuble        Int?

  vues VueOpportunite[]
}

model Deblocage {
  id              String      @id @default(cuid())
  acheteurId      String
  acheteur        Acheteur    @relation(fields: [acheteurId], references: [id], onDelete: Cascade)
  opportuniteId   String
  opportunite     Opportunite @relation(fields: [opportuniteId], references: [id], onDelete: Cascade)

  stripePaymentId String?
  paidAt          DateTime?

  packCommission  Int?
  packAccepte     Boolean  @default(false)
  packAccepteAt   DateTime?

  contactDemande  Boolean  @default(false)
  contactAt       DateTime?
  conversation    Conversation?
  createdAt       DateTime @default(now())

  @@unique([acheteurId, opportuniteId])
}

model Conversation {
  id          String    @id @default(cuid())
  deblocageId String    @unique
  deblocage   Deblocage @relation(fields: [deblocageId], references: [id], onDelete: Cascade)
  messages    Message[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  attachmentUrl   String?
  attachmentName  String?
}

model VueOpportunite {
  id            String   @id @default(cuid())
  opportuniteId String
  opportunite   Opportunite @relation(fields: [opportuniteId], references: [id], onDelete: Cascade)
  type          String   // "publique" ou "abonne"
  date          DateTime @default(now())
}

model Article {
  id          String    @id @default(cuid())
  titre       String
  slug        String    @unique
  contenu     String    // HTML généré par Tiptap
  extrait     String?   // résumé pour les cards
  coverImage  String?   // URL Cloudinary
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}